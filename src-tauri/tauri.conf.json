{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scribe",
  "version": "0.1.0",
  "identifier": "com.alexb151.scribe",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Scribe",
        "width": 620,
        "height": 560,
        "visible": false,
        "center": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
